  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lighthouse": "lighthouse http://localhost:5173 --output html --output-path ./lighthouse-report.html",
    "format": "yarn biome format --write .",
    "lint": "yarn biome lint --write .",
    "check": "yarn biome check --write .",
    "preview": "vite preview",
    "scssformat": "yarn biome format --write . && prettier --write \"**/*.scss\""
  },
