    "dompurify": "^3.2.6",
    "framer-motion": "^11.11.9",
    "highlight.js": "^11.11.1",
    "html-react-parser": "^5.2.5",
    "lucide-react": "^0.544.0",
    "quill": "^2.0.2",
    "quill-delta": "^5.1.0",
    "quill-delta-to-html": "^0.12.1",
